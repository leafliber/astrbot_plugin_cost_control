{
  "enabled": {
    "description": "启用本插件",
    "hint": "总开关。其余所有详细配置（预算 / 单价 / 策略 / 阈值 / 时间等）请在「仪表盘 → 设置」页调整，支持热生效",
    "type": "bool",
    "default": true
  },
  "platforms": {
    "description": "生效平台列表",
    "hint": "为空则全部平台生效。详细配置请在「仪表盘 → 设置」页调整",
    "type": "list",
    "default": [],
    "items": {
      "description": "平台 ID",
      "hint": "如 aiocqhttp、telegram_official 等",
      "type": "string",
      "default": ""
    }
  },
  "alerts": {
    "description": "告警功能开关",
    "hint": "仅保留启用开关；冷却时间 / 推送时间 / 推送目标 等详细配置请在「仪表盘 → 设置」页调整",
    "type": "object",
    "default": {},
    "items": {
      "enabled": {
        "description": "启用超预算主动推送",
        "type": "bool",
        "default": true
      }
    }
  },
  "cache_diag": {
    "description": "缓存诊断开关",
    "hint": "仅保留四类检测开关；命中率告警阈值等详细配置请在「仪表盘 → 设置」页调整",
    "type": "object",
    "default": {},
    "items": {
      "detect_context_reset": {
        "description": "上下文重置检测",
        "type": "bool",
        "default": true
      },
      "detect_system_prompt_change": {
        "description": "system prompt 变更检测",
        "type": "bool",
        "default": true
      },
      "detect_tools_change": {
        "description": "工具定义变更检测",
        "type": "bool",
        "default": true
      },
      "detect_order_drift": {
        "description": "上下文顺序漂移检测",
        "type": "bool",
        "default": true
      }
    }
  },
  "prompt_optimizer": {
    "description": "提示词优化开关",
    "hint": "仅保留启用开关；改写 Provider / 最大分析长度 等详细配置请在「仪表盘 → 设置」页调整",
    "type": "object",
    "default": {},
    "items": {
      "enabled": {
        "description": "启用提示词优化",
        "type": "bool",
        "default": true
      }
    }
  },
  "attribution": {
    "description": "归因分析开关",
    "hint": "仅保留启用开关；采样率等详细配置请在「仪表盘 → 设置」页调整",
    "type": "object",
    "default": {},
    "items": {
      "enabled": {
        "description": "启用上下文注入归因",
        "type": "bool",
        "default": true
      }
    }
  },
  "schedule": {
    "description": "定时任务开关",
    "hint": "仅保留日报开关；历史保留天数等详细配置请在「仪表盘 → 设置」页调整",
    "type": "object",
    "default": {},
    "items": {
      "enable_daily_report": {
        "description": "启用每日报告 CronJob",
        "type": "bool",
        "default": false
      }
    }
  }
}
